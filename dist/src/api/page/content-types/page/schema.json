{
    "kind": "collectionType",
    "collectionName": "pages",
    "info": {
        "singularName": "page",
        "pluralName": "pages",
        "displayName": "Page",
        "description": "Static pages like About Us"
    },
    "options": {
        "draftAndPublish": true
    },
    "pluginOptions": {},
    "attributes": {
        "title": {
            "type": "string",
            "required": true
        },
        "slug": {
            "type": "uid",
            "targetField": "title"
        },
        "content": {
            "type": "richtext"
        },
        "heroImage": {
            "type": "media",
            "multiple": false,
            "required": false,
            "allowedTypes": ["images"]
        }
    }
}
